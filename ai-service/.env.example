# ==============================
# Canim AI Service Configuration
# ==============================

# Môi trường chạy app: development / production
APP_ENV=development

# Tên service để log/debug dễ hiểu
APP_NAME=Canim AI Service

# Port chạy FastAPI
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8001

# URL backend Spring Boot Canim_Ecommerce
# Backend hiện chạy port 8000 và context path /canim_ecommerce
BACKEND_BASE_URL=http://localhost:8000/canim_ecommerce

# API lấy product context từ backend
# Sau này Python AI dùng endpoint này để đọc sản phẩm sạch cho AI
BACKEND_PRODUCT_CONTEXT_PATH=/ai/products/context

# Cho phép frontend React gọi Python AI
CUSTOMER_FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

# Chế độ AI hiện tại
# rule_based: dùng luật đơn giản, miễn phí, dễ debug
# ml: dùng model scikit-learn đã train
AI_NLU_MODE=rule_based

# Có bật log debug không
DEBUG=true