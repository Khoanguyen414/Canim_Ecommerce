# Copy to .env for local development or set on Render/Koyeb/Railway.

APP_ENV=production
APP_NAME=Canim AI Service
AI_DEBUG=false

# Server (AI_PORT is used by Docker; AI_SERVICE_PORT is legacy alias)
AI_SERVICE_HOST=0.0.0.0
AI_PORT=8001
AI_SERVICE_PORT=8001

# Backend Spring Boot API (include context path /canim_ecommerce)
BACKEND_API_BASE_URL=http://backend:8080/canim_ecommerce
BACKEND_BASE_URL=http://backend:8080/canim_ecommerce
BACKEND_PRODUCT_CONTEXT_PATH=/ai/products/context
BACKEND_PRODUCTS_PATH=/products?pageNum=1&sizePage=100

# CORS — comma-separated origins (overrides customer/admin URLs when set)
AI_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Used when AI_CORS_ALLOWED_ORIGINS is empty
CUSTOMER_FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

AI_NLU_MODE=rule_based
