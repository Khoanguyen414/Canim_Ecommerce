# Storefront (Vite) — copy to .env.local for development.
# Production: set these in Cloudflare Pages / Vercel project settings before build.

VITE_API_BASE_URL=http://localhost:8080/canim_ecommerce
VITE_AI_API_BASE_URL=http://localhost:8001
VITE_AI_CHAT_MOCK=false

# Public OAuth client ID (same as Google Cloud console)
VITE_GOOGLE_CLIENT_ID=

# Optional maps widget
VITE_GOOGLE_MAPS_API_KEY=
