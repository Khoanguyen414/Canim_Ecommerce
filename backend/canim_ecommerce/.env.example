# Sao chép thành .env (hoặc set trong IDE / hệ thống) — KHÔNG commit file .env có secret thật.

MYSQL_PASSWORD=root
REDIS_HOST=localhost

# sandbox | production
PAYMENT_ENV=sandbox
# spring.profiles.active=production

# --- VNPay (merchant https://vnpay.vn) ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# Chỉ cần nếu muốn ghi đè URL mặc định theo PAYMENT_ENV
# VNPAY_PAY_URL=https://pay.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment/vnpay-return
VNPAY_IPN_URL=http://localhost:8000/canim_ecommerce/payments/vnpay/ipn

# --- MoMo Business (https://business.momo.vn) ---
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
# MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:5173/payment/momo-return
MOMO_NOTIFY_URL=http://localhost:8000/canim_ecommerce/payments/momo/notify

# URL công khai HTTPS khi deploy (ngrok hoặc server thật) — bắt buộc cho IPN/notify production
# PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.app/canim_ecommerce
# PUBLIC_FRONTEND_URL=https://your-shop.com
