# Copy to .env for local Docker Compose or set on Render/Koyeb/Railway.
# Never commit real secrets.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/canim_ecommerce

# --- MySQL (required) ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=canim_ecommerce
MYSQL_USER=canim
MYSQL_PASSWORD=change-me

# --- Redis (optional: set REDIS_ENABLED=false to disable) ---
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false

# --- JWT (required) ---
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRATION=10
JWT_REFRESH_EXPIRATION=1

# --- CORS (comma-separated origin patterns) ---
# Example: https://canim-shop.pages.dev,https://canim-admin.pages.dev,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:*

# --- Google OAuth (backend verifies ID token; client secret not used server-side) ---
GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudinary (recommended for production image uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
APP_STORAGE_MODE=cloudinary
APP_STORAGE_PUBLIC_URL=

# --- Personal QR payment (graduation demo) ---
PERSONAL_QR_BANK_CODE=970454
PERSONAL_QR_ACCOUNT_NO=
PERSONAL_QR_ACCOUNT_NAME=
MOMO_QR_PHONE=
VNPAY_QR_ACCOUNT_NUMBER=

# --- Payment gateways (optional) ---
PAYMENT_ENV=sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:5173/payment/vnpay-return
VNPAY_IPN_URL=http://localhost:8080/canim_ecommerce/payments/vnpay/ipn
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_RETURN_URL=http://localhost:5173/payment/momo-return
MOMO_NOTIFY_URL=http://localhost:8080/canim_ecommerce/payments/momo/notify

# --- URLs ---
PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
PUBLIC_FRONTEND_URL=http://localhost:5173

# Reserved for future backend → AI integration (not required today)
AI_SERVICE_URL=http://ai-service:8001
